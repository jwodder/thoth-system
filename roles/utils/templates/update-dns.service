[Unit]
Description=Update system DNS record

[Service]
Type=oneshot
ExecStart=/home/{{ admin_user|quote }}/.local/bin/update-dns {{ jwodder_root|quote }}/etc/utils.toml
ExecStopPost=/home/{{ admin_user|quote }}/.local/bin/mail-systemd-failure {{ jwodder_root|quote }}/etc/utils.toml %n
User={{ admin_user }}
Group={{ admin_user }}
